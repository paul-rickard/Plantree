{
  "id": "wfp_default",
  "type": "workflowProfile",
  "key": "default",
  "name": "Default work-order workflow",
  "description": "The out-of-the-box lifecycle from doc 05, expressed as a configurable state machine. States carry only an id + label; terminality is derived (closed and rejected have no outgoing transitions), entry points are explicit, and guards are boolean expressions.",
  "isDefault": true,
  "rev": 0,
  "createdAt": "2026-07-14T00:00:00Z",
  "updatedAt": "2026-07-14T00:00:00Z",
  "entryStates": ["requested", "planned", "scheduled"],
  "states": [
    { "id": "requested", "label": "Requested" },
    { "id": "reviewed", "label": "Reviewed" },
    { "id": "approved", "label": "Approved" },
    { "id": "planned", "label": "Planned" },
    { "id": "scheduled", "label": "Scheduled" },
    { "id": "assigned", "label": "Assigned" },
    { "id": "in_progress", "label": "In progress" },
    { "id": "awaiting_parts_access", "label": "Awaiting parts/access" },
    { "id": "completed", "label": "Completed" },
    { "id": "verified", "label": "Verified" },
    { "id": "closed", "label": "Closed" },
    { "id": "rejected", "label": "Rejected" },
    { "id": "cancelled", "label": "Cancelled" }
  ],
  "transitions": [
    { "from": "requested", "to": "reviewed", "label": "Triage", "trigger": { "type": "manual" } },
    { "from": "requested", "to": "rejected", "label": "Reject", "trigger": { "type": "manual" }, "guards": ["role('approver')"] },
    { "from": "requested", "to": "cancelled", "label": "Cancel", "trigger": { "type": "manual" } },
    { "from": "reviewed", "to": "approved", "label": "Approve", "trigger": { "type": "manual" }, "guards": ["role('approver')", "withinApprovalLimit()"] },
    { "from": "reviewed", "to": "rejected", "label": "Reject", "trigger": { "type": "manual" }, "guards": ["role('approver')"] },
    { "from": "approved", "to": "planned", "label": "Plan", "trigger": { "type": "manual" }, "guards": ["jobPlanPresent()", "labourEstimatePresent()"] },
    { "from": "planned", "to": "scheduled", "label": "Schedule", "trigger": { "type": "manual" }, "guards": ["partsReserved()", "windowSet()"], "actions": [{ "type": "reserve_parts" }] },
    { "from": "scheduled", "to": "assigned", "label": "Assign", "trigger": { "type": "manual" }, "guards": ["skillsMatch()"], "actions": [{ "type": "notify", "target": "assignee" }] },
    { "from": "assigned", "to": "in_progress", "label": "Start work", "trigger": { "type": "manual" }, "guards": ["permitsIssued()", "assetStatusAllows()"] },
    { "from": "in_progress", "to": "awaiting_parts_access", "label": "Put on hold", "trigger": { "type": "manual" } },
    { "from": "awaiting_parts_access", "to": "in_progress", "label": "Resume", "trigger": { "type": "manual" } },
    { "from": "in_progress", "to": "completed", "label": "Complete", "trigger": { "type": "manual" }, "guards": ["actualsCaptured()"], "actions": [{ "type": "deduct_stock" }] },
    { "from": "in_progress", "to": "cancelled", "label": "Cancel", "trigger": { "type": "manual" } },
    { "from": "completed", "to": "in_progress", "label": "Rework", "trigger": { "type": "manual" } },
    { "from": "completed", "to": "verified", "label": "Verify", "trigger": { "type": "manual" }, "guards": ["role('supervisor')"] },
    { "from": "completed", "to": "closed", "trigger": { "type": "timer", "afterDays": 5 } },
    { "from": "verified", "to": "closed", "label": "Close", "trigger": { "type": "manual" }, "actions": [{ "type": "finalise_costs" }] },
    { "from": "cancelled", "to": "closed", "trigger": { "type": "onEntry" }, "actions": [{ "type": "finalise_costs" }] }
  ]
}
