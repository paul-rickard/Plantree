      "estimatedLabourHours": 1.5,
      "safetyInstructions": "Confirm the UPS is on bypass or that redundant path A/B covers the load before any intrusive check. Battery work: insulated tools, face shield, no rings/watches.",
      "tasks": [
        {
          "seq": 1,
          "instruction": "Record input voltage (each phase).",
          "responseType": "numeric",
          "unit": "V",
          "acceptableRange": [370, 440],
          "choices": null,
          "requiredSkills": []
        },
        {
          "seq": 2,
          "instruction": "Record output voltage (each phase).",
          "responseType": "numeric",
          "unit": "V",
          "acceptableRange": [395, 420],
          "choices": null,
          "requiredSkills": []
        },
        {
          "seq": 3,
          "instruction": "Measure battery impedance per string.",
          "responseType": "numeric",
          "unit": "mOhm",
          "acceptableRange": [0, 4.5],
          "choices": null,
          "requiredSkills": ["Battery maintenance"]
        },
        {
          "seq": 4,
          "instruction": "Check cooling fans and air filters; clean or flag for replacement.",
          "responseType": "passfail",
          "unit": null,
          "acceptableRange": null,
          "choices": null,
          "requiredSkills": []
        },
        {
          "seq": 5,
          "instruction": "Review event log; note any alarms since last visit.",
          "responseType": "text",
          "unit": null,
          "acceptableRange": null,
          "choices": null,
          "requiredSkills": []
        },
        {
          "seq": 6,
          "instruction": "Overall unit condition.",
          "responseType": "choice",
          "unit": null,
          "acceptableRange": null,
          "choices": ["Good", "Monitor", "Action required"],
          "requiredSkills": []
        }
      ],
      "plannedParts": [
        { "partRef": null, "description": "Air filter, G4 panel", "quantity": 1, "unit": "each" }
      ],
      "requiredSkills": ["Electrical – LV", "Battery maintenance"],
      "requiredTools": ["Battery impedance tester", "Insulated tool kit"],
      "requiredPermits": ["Electrical work permit"],
      "parameters": [
        { "key": "batteryStringCount", "label": "Battery strings", "valueType": "number", "defaultValue": 3, "unit": null, "source": "asset" },
        { "key": "acceptableImpedanceMilliOhm", "label": "Max cell impedance", "valueType": "number", "defaultValue": 4.5, "unit": "mOhm", "source": "model" }
